# Required: Feishu App credentials
AUGUR_APP_ID=cli_xxx
AUGUR_APP_SECRET=xxx

# Optional: Claude auth (omit for OAuth mode)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: Feishu event security
# AUGUR_ENCRYPT_KEY=
# AUGUR_VERIFICATION_TOKEN=

# Optional: overrides
# AUGUR_WORKING_DIR=~/Desktop/Toys/augur/data
# AUGUR_MODEL=claude-sonnet-4-5
# AUGUR_FEISHU_DOMAIN=https://open.feishu.cn
